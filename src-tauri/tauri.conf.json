{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RawAccel Profile Manager",
  "version": "0.1.0",
  "identifier": "pro.osin.tools.rawaccel.profile.manager.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RawAccel Profile Manager",
        "width": 980,
        "height": 800,
        "decorations": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
